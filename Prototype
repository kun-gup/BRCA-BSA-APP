<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>BRCA Trophy — Satpura Hostel</title>
<style>
  *{box-sizing:border-box;}
  body{margin:0;}
  .app-outer{
    --forest:#1F3D2E; --forest-deep:#142A20; --gold:#C9A227; --rust:#A1492A;
    --cream:#F6F2E9; --ink:#1B1B17; --ink-70:rgba(27,27,23,.7); --ink-40:rgba(27,27,23,.45);
    --ink-30:rgba(27,27,23,.32); --ink-15:rgba(27,27,23,.13); --ink-08:rgba(27,27,23,.07);
    --card:#FFFFFF;
    font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
    display:flex; justify-content:center; padding:24px 12px; min-height:100vh;
    background:#EDE7D8;
  }
  .phone{
    width:390px; max-width:100%; height:780px; background:var(--cream);
    border-radius:36px; border:8px solid var(--forest-deep); overflow:hidden;
    display:flex; flex-direction:column; position:relative; box-shadow:0 20px 50px rgba(20,42,32,.25);
  }
  .statusbar{ height:14px; background:var(--forest-deep); flex-shrink:0; }
  .scroll-area{ flex:1; overflow-y:auto; padding:20px 18px 8px; }
  .screen-head{ margin-bottom:18px; }
  .eyebrow{ font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--rust); font-weight:700; margin-bottom:4px; }
  h1{ font-family:Georgia, 'Times New Roman', serif; font-size:30px; font-weight:700; color:var(--forest-deep); margin:0; letter-spacing:-.01em; }

  .seg{ display:flex; background:var(--ink-08); border-radius:12px; padding:4px; margin-bottom:14px; }
  .seg-btn{ flex:1; border:none; background:transparent; padding:9px 0; font-size:13px; font-weight:600; color:var(--ink-40); border-radius:9px; cursor:pointer; font-family:inherit; }
  .seg-btn.active{ background:var(--card); color:var(--forest-deep); box-shadow:0 1px 4px rgba(0,0,0,.08); }

  .chiprow{ display:flex; gap:8px; overflow-x:auto; padding-bottom:14px; }
  .chip{ flex-shrink:0; border:1px solid var(--ink-15); background:var(--card); padding:7px 14px; border-radius:999px; font-size:12.5px; font-weight:600; color:var(--ink-70); cursor:pointer; font-family:inherit; }
  .chip.active{ background:var(--forest); color:var(--cream); border-color:var(--forest); }

  .board{ display:flex; flex-direction:column; gap:6px; }
  .board-row{ display:flex; align-items:center; gap:12px; background:var(--card); padding:12px 14px; border-radius:14px; border:1px solid var(--ink-08); }
  .board-row.mine{ border:1.5px solid var(--gold); background:linear-gradient(0deg, rgba(201,162,39,.07), rgba(201,162,39,.07)), var(--card); }
  .rank{ font-family:Georgia,serif; font-size:18px; font-weight:700; width:26px; flex-shrink:0; }
  .board-mid{ flex:1; min-width:0; }
  .board-name{ font-size:14px; font-weight:700; color:var(--ink); display:flex; align-items:center; gap:6px; margin-bottom:5px; }
  .us-tag{ font-size:9px; background:var(--gold); color:var(--forest-deep); padding:1px 6px; border-radius:5px; letter-spacing:.05em; font-weight:800; }
  .board-bar-track{ height:5px; background:var(--ink-08); border-radius:3px; overflow:hidden; }
  .board-bar-fill{ height:100%; border-radius:3px; }
  .board-pts{ font-size:14px; font-weight:800; color:var(--forest-deep); font-variant-numeric:tabular-nums; }

  .cal-card{ background:var(--card); border-radius:18px; padding:14px; border:1px solid var(--ink-08); margin-bottom:18px; }
  .cal-weekdays{ display:grid; grid-template-columns:repeat(7,1fr); margin-bottom:6px; }
  .cal-wd{ text-align:center; font-size:10.5px; font-weight:700; color:var(--ink-30); }
  .cal-grid{ display:grid; grid-template-columns:repeat(7,1fr); gap:3px; }
  .cal-cell{ aspect-ratio:1; border:none; background:transparent; border-radius:10px; cursor:pointer; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:3px; font-family:inherit; padding:0; }
  .cal-cell.empty{ cursor:default; }
  .cal-cell.sel{ background:var(--forest); }
  .cal-cell.sel .cal-num{ color:var(--cream); }
  .cal-num{ font-size:12.5px; font-weight:600; color:var(--ink-70); }
  .cal-markers{ display:flex; gap:2px; }
  .marker{ width:4px; height:4px; border-radius:50%; background:var(--rust); display:inline-block; }
  .marker-start{ background:var(--gold); border-radius:2px 0 0 2px; width:6px; }
  .marker-mid{ background:var(--gold); opacity:.6; }
  .marker-end{ background:var(--gold); border-radius:0 2px 2px 0; width:6px; }

  .day-list-head{ font-size:12px; font-weight:700; color:var(--ink-40); text-transform:uppercase; letter-spacing:.06em; margin-bottom:10px; }
  .day-list{ display:flex; flex-direction:column; gap:8px; }
  .event-row{ display:flex; align-items:center; gap:10px; background:var(--card); border:1px solid var(--ink-08); border-radius:14px; padding:12px; cursor:pointer; font-family:inherit; text-align:left; width:100%; }
  .event-dot{ width:9px; height:9px; border-radius:50%; flex-shrink:0; }
  .event-dot.competitive{ background:var(--rust); }
  .event-dot.workshop{ background:var(--gold); }
  .event-dot.non_competitive{ background:var(--forest); }
  .event-mid{ flex:1; min-width:0; }
  .event-title{ font-size:13.5px; font-weight:700; color:var(--ink); margin-bottom:2px; }
  .event-sub{ font-size:12px; color:var(--ink-40); }

  .back-btn{ display:flex; align-items:center; gap:4px; border:none; background:transparent; color:var(--ink-40); font-size:13px; font-weight:600; padding:0 0 16px; cursor:pointer; font-family:inherit; }
  .detail-card{ background:var(--card); border:1px solid var(--ink-08); border-radius:20px; padding:20px; }
  .detail-tag{ display:inline-block; font-size:10.5px; font-weight:800; letter-spacing:.06em; text-transform:uppercase; padding:4px 10px; border-radius:999px; margin-bottom:12px; }
  .detail-tag.competitive{ background:rgba(161,73,42,.12); color:var(--rust); }
  .detail-tag.workshop{ background:rgba(201,162,39,.15); color:#8a6c10; }
  .detail-title{ font-family:Georgia,serif; font-size:24px; color:var(--forest-deep); margin:0 0 4px; line-height:1.15; }
  .detail-club{ font-size:13px; color:var(--ink-40); font-weight:600; margin-bottom:18px; }
  .detail-rows{ display:flex; flex-direction:column; gap:11px; margin-bottom:20px; padding-bottom:20px; border-bottom:1px solid var(--ink-08); }
  .detail-row{ display:flex; align-items:center; gap:10px; font-size:13.5px; color:var(--ink-70); }
  .detail-row svg{ flex-shrink:0; }
  .ghost-btn{ width:100%; display:flex; align-items:center; justify-content:center; gap:8px; background:transparent; border:1.5px solid var(--ink-15); color:var(--forest-deep); padding:13px; border-radius:13px; font-size:13.5px; font-weight:700; cursor:pointer; margin-bottom:10px; font-family:inherit; }
  .primary-btn{ width:100%; display:flex; align-items:center; justify-content:center; gap:8px; background:var(--forest); border:none; color:var(--cream); padding:14px; border-radius:13px; font-size:13.5px; font-weight:700; cursor:pointer; font-family:inherit; }
  .info-card{ background:var(--ink-08); padding:14px; border-radius:13px; font-size:13px; color:var(--ink-70); line-height:1.5; }

  .notice-list{ display:flex; flex-direction:column; gap:10px; }
  .notice-card{ background:var(--card); border:1px solid var(--ink-08); border-radius:16px; padding:14px; }
  .notice-top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
  .scope-pill{ font-size:10px; font-weight:800; letter-spacing:.05em; text-transform:uppercase; padding:3px 9px; border-radius:999px; }
  .notice-title{ font-size:14px; font-weight:700; color:var(--ink); margin-bottom:4px; }
  .notice-body{ font-size:12.5px; color:var(--ink-70); line-height:1.5; margin-bottom:8px; }
  .notice-time{ font-size:11px; color:var(--ink-30); font-weight:600; }

  .more-section{ background:var(--card); border:1px solid var(--ink-08); border-radius:16px; overflow:hidden; margin-bottom:18px; }
  .more-row{ display:flex; align-items:center; gap:12px; padding:14px 16px; border-bottom:1px solid var(--ink-08); cursor:pointer; }
  .more-row:last-child{ border-bottom:none; }
  .more-mid{ flex:1; min-width:0; }
  .more-title{ font-size:13.5px; font-weight:700; color:var(--ink); margin-bottom:2px; }
  .more-sub{ font-size:11.5px; color:var(--ink-40); }
  .profile-card{ display:flex; align-items:center; gap:12px; background:var(--forest); padding:16px; border-radius:16px; }
  .profile-avatar{ width:42px; height:42px; border-radius:50%; background:var(--gold); color:var(--forest-deep); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:14px; flex-shrink:0; }
  .profile-card .more-title{ color:var(--cream); }
  .profile-card .more-sub{ color:rgba(246,242,233,.65); }

  .tabbar{ display:flex; border-top:1px solid var(--ink-08); background:var(--card); padding:10px 8px 14px; flex-shrink:0; }
  .tab-btn{ flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; background:transparent; border:none; cursor:pointer; padding:4px; font-family:inherit; }
  .tab-label{ font-size:10px; font-weight:700; color:var(--ink-30); }
  .tab-btn.active .tab-label{ color:var(--forest); }

  .scroll-area::-webkit-scrollbar{ width:0; }
  button{ -webkit-tap-highlight-color: transparent; }
</style>
</head>
<body>
<div class="app-outer">
  <div class="phone">
    <div class="statusbar"></div>
    <div class="scroll-area" id="scrollArea"></div>
    <div class="tabbar" id="tabbar"></div>
  </div>
</div>

<script>
// ---------------- Mock data ----------------
var HOSTELS = [
  { code: "SAT", name: "Satpura", points: 1240, mine: true },
  { code: "KAR", name: "Karakoram", points: 1310, mine: false },
  { code: "ARV", name: "Aravali", points: 1185, mine: false },
  { code: "HIM", name: "Himadri", points: 1095, mine: false },
  { code: "NIL", name: "Nilgiri", points: 1020, mine: false },
  { code: "VIN", name: "Vindhyachal", points: 980, mine: false },
  { code: "JWA", name: "Jwalamukhi", points: 940, mine: false },
  { code: "ZAN", name: "Zanskar", points: 905, mine: false },
  { code: "KUM", name: "Kumaon", points: 860, mine: false },
  { code: "SHI", name: "Shivalik", points: 820, mine: false },
  { code: "UDA", name: "Udaigiri", points: 790, mine: false },
  { code: "GIR", name: "Girnar", points: 740, mine: false },
  { code: "DHA", name: "Dhauladhar", points: 690, mine: false }
].sort(function(a, b){ return b.points - a.points; });

var CLUBS = ["Dance", "Music", "Dramatics", "Fine Arts", "Quiz & Lit", "Photography"];

var EVENTS = [
  { id: 1, title: "Western Dance Prelims", club: "Dance", start: 3, end: 3, time: "7:00 PM", venue: "OAT", points: 150, type: "competitive", reg: "external", rulebook: true },
  { id: 2, title: "Inter-Hostel Battle of Bands", club: "Music", start: 7, end: 8, time: "6:30 PM", venue: "SAC Lawns", points: 200, type: "competitive", reg: "external", rulebook: true },
  { id: 3, title: "Street Play Finals", club: "Dramatics", start: 12, end: 12, time: "8:00 PM", venue: "OAT", points: 180, type: "competitive", reg: "notify", rulebook: true },
  { id: 4, title: "Freshers' Sketch Workshop", club: "Fine Arts", start: 15, end: 15, time: "5:00 PM", venue: "Satpura Common Room", points: 0, type: "workshop", reg: "notify", rulebook: false },
  { id: 5, title: "Quiz League — Round 2", club: "Quiz & Lit", start: 18, end: 18, time: "9:00 PM", venue: "LH 101", points: 120, type: "competitive", reg: "external", rulebook: true },
  { id: 6, title: "Photo Trail", club: "Photography", start: 21, end: 24, time: "All day", venue: "Campus-wide", points: 90, type: "competitive", reg: "external", rulebook: true }
];

var NOTICES = [
  { id: 1, scope: "club", club: "Dance", title: "Practice shifted to OAT tonight", body: "Due to SAC Lawns being booked, today's practice moves to OAT, 7 PM sharp.", pinned: true, time: "2h ago" },
  { id: 2, scope: "hostel", title: "Mess timing change during BRCA week", body: "Dinner extended to 10:30 PM on event days to accommodate rehearsals.", pinned: true, time: "5h ago" },
  { id: 3, scope: "institute", title: "BRCA Week schedule released", body: "The full inter-hostel calendar for the season is now live on the app.", pinned: false, time: "1d ago" },
  { id: 4, scope: "club", club: "Music", title: "Battle of Bands — slot confirmation", body: "Satpura plays 2nd slot, 7:15 PM. Soundcheck at 6:30.", pinned: false, time: "2d ago" }
];

var SCOPE_STYLE = {
  institute: { label: "Institute", color: "#C9A227" },
  hostel: { label: "Hostel", color: "#1F3D2E" },
  club: { label: "Club", color: "#A1492A" }
};

// ---------------- Tiny inline icon SVGs ----------------
function icon(name, size, color){
  size = size || 18; color = color || "currentColor";
  var paths = {
    trophy: '<path d="M8 21h8M12 17v4M7 4h10v4a5 5 0 0 1-10 0V4Z"/><path d="M7 5H4a3 3 0 0 0 3 5M17 5h3a3 3 0 0 1-3 5"/>',
    calendar: '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 10h18"/>',
    bell: '<path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6Z"/><path d="M10.3 20a1.9 1.9 0 0 0 3.4 0"/>',
    more: '<circle cx="5" cy="12" r="1.4"/><circle cx="12" cy="12" r="1.4"/><circle cx="19" cy="12" r="1.4"/>',
    chevLeft: '<path d="M15 18l-6-6 6-6"/>',
    chevRight: '<path d="M9 18l6-6-6-6"/>',
    pin: '<path d="M12 17v5M9 10.76 5 12l3 4 4-1V4l-3 1.76V10.76Z"/>',
    mapPin: '<path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 1 1 18 0Z"/><circle cx="12" cy="10" r="3"/>',
    clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>',
    fileText: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6M8 13h8M8 17h8M8 9h2"/>',
    extLink: '<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6M10 14 21 3"/>',
    pkg: '<path d="m16.5 9.4-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.27 6.96 8.73 5.04 8.73-5.04M12 22.08V12"/>',
    msgWarn: '<path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.4 8.5 8.5 0 0 1-4-1L3 20l1.1-5.5a8.38 8.38 0 0 1-1-4 8.4 8.4 0 0 1 8.4-8.5 8.38 8.38 0 0 1 9.5 8.5Z"/><path d="M12 8v3M12 14h.01"/>',
    alertCircle: '<circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/>'
  };
  return '<svg width="'+size+'" height="'+size+'" viewBox="0 0 24 24" fill="none" stroke="'+color+'" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">'+(paths[name]||'')+'</svg>';
}

// ---------------- State ----------------
var state = { tab: "leaderboard", boardView: "overall", selectedDay: 7, openEvent: null };

function setState(patch){
  Object.assign(state, patch);
  render();
}

function rankColor(i){
  if (i === 0) return "#C9A227";
  if (i === 1) return "#B8C0C8";
  if (i === 2) return "#A1492A";
  return "rgba(27,27,23,.45)";
}

function esc(s){
  var d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

// ---------------- Screen renderers (return HTML strings) ----------------
function renderLeaderboard(){
  var maxPts = HOSTELS[0].points;
  var segHtml =
    '<div class="seg">' +
      '<button class="seg-btn ' + (state.boardView==="overall"?"active":"") + '" data-action="board-overall">Overall</button>' +
      '<button class="seg-btn ' + (state.boardView==="club"?"active":"") + '" data-action="board-club">By Club</button>' +
    '</div>';
  var chipsHtml = '';
  if (state.boardView === "club"){
    chipsHtml = '<div class="chiprow">' + CLUBS.map(function(c){ return '<button class="chip">'+esc(c)+'</button>'; }).join('') + '</div>';
  }
  var rows = HOSTELS.map(function(h, i){
    var pct = (h.points / maxPts) * 100;
    return (
      '<div class="board-row ' + (h.mine?"mine":"") + '">' +
        '<div class="rank" style="color:' + rankColor(i) + '">' + String(i+1).padStart(2,"0") + '</div>' +
        '<div class="board-mid">' +
          '<div class="board-name">' + esc(h.name) + (h.mine ? ' <span class="us-tag">YOU</span>' : '') + '</div>' +
          '<div class="board-bar-track"><div class="board-bar-fill" style="width:'+pct+'%;background:' + (h.mine?"var(--gold)":"var(--ink-15)") + '"></div></div>' +
        '</div>' +
        '<div class="board-pts">' + h.points + '</div>' +
      '</div>'
    );
  }).join('');
  return (
    '<div class="screen-head"><div class="eyebrow">Season II · Live Standings</div><h1>Leaderboard</h1></div>' +
    segHtml + chipsHtml +
    '<div class="board">' + rows + '</div>'
  );
}

function eventsOnDay(d){
  return EVENTS.filter(function(e){ return d >= e.start && d <= e.end; });
}

function renderCalendar(){
  var daysInMonth = 30;
  var firstWeekday = 5;
  var cells = '';
  for (var i = 0; i < firstWeekday; i++) cells += '<div class="cal-cell empty"></div>';
  for (var d = 1; d <= daysInMonth; d++){
    var evs = eventsOnDay(d);
    var isSel = d === state.selectedDay;
    var markers = '';
    if (evs.length){
      markers = '<div class="cal-markers">' + evs.slice(0,3).map(function(e){
        var kind = 'single';
        if (e.start !== e.end){
          if (d === e.start) kind = 'start';
          else if (d === e.end) kind = 'end';
          else kind = 'mid';
        }
        return '<span class="marker marker-'+kind+'"></span>';
      }).join('') + '</div>';
    }
    cells += '<button class="cal-cell ' + (isSel?"sel":"") + '" data-action="select-day" data-day="'+d+'"><span class="cal-num">'+d+'</span>'+markers+'</button>';
  }
  var weekdays = ["S","M","T","W","T","F","S"].map(function(w){ return '<div class="cal-wd">'+w+'</div>'; }).join('');

  var dayEvents = eventsOnDay(state.selectedDay);
  var headText = dayEvents.length ? (dayEvents.length + ' event' + (dayEvents.length>1?'s':'') + ' on Nov ' + state.selectedDay) : ('No events on Nov ' + state.selectedDay);
  var eventRows = dayEvents.map(function(e){
    var dayLabel = e.start !== e.end ? (' · Day ' + (state.selectedDay - e.start + 1)) : '';
    return (
      '<button class="event-row" data-action="open-event" data-id="'+e.id+'">' +
        '<div class="event-dot ' + e.type + '"></div>' +
        '<div class="event-mid">' +
          '<div class="event-title">' + esc(e.title) + '</div>' +
          '<div class="event-sub">' + esc(e.club) + ' · ' + esc(e.time) + dayLabel + '</div>' +
        '</div>' +
        icon('chevRight', 16, 'rgba(27,27,23,.32)') +
      '</button>'
    );
  }).join('');

  return (
    '<div class="screen-head"><div class="eyebrow">November</div><h1>Calendar</h1></div>' +
    '<div class="cal-card"><div class="cal-weekdays">'+weekdays+'</div><div class="cal-grid">'+cells+'</div></div>' +
    '<div class="day-list-head">'+headText+'</div>' +
    '<div class="day-list">'+eventRows+'</div>'
  );
}

function renderEventDetail(eventId){
  var e = EVENTS.filter(function(ev){ return ev.id === eventId; })[0];
  if (!e) return '';
  var typeLabel = e.type === "competitive" ? "Competitive" : e.type === "workshop" ? "Workshop" : "Non-competitive";
  var dateLine = e.start !== e.end ? ('Nov ' + e.start + '–' + e.end) : ('Nov ' + e.start);
  var rows =
    '<div class="detail-row">' + icon('clock',16,'#1F3D2E') + '<span>' + esc(e.time) + ' · ' + dateLine + '</span></div>' +
    '<div class="detail-row">' + icon('mapPin',16,'#1F3D2E') + '<span>' + esc(e.venue) + '</span></div>' +
    (e.points > 0 ? '<div class="detail-row">' + icon('trophy',16,'#1F3D2E') + '<span>' + e.points + ' points on offer</span></div>' : '');
  var rulebookBtn = e.rulebook ? ('<button class="ghost-btn">' + icon('fileText',16) + ' View rulebook PDF</button>') : '';
  var regBlock = e.reg === "external"
    ? ('<button class="primary-btn">' + icon('extLink',16,'#F6F2E9') + ' Open registration form</button>')
    : '<div class="info-card">Registration isn\'t external — contact your club rep to be added.</div>';

  return (
    '<button class="back-btn" data-action="back-to-calendar">' + icon('chevLeft',18) + ' Back to calendar</button>' +
    '<div class="detail-card">' +
      '<div class="detail-tag ' + e.type + '">' + typeLabel + '</div>' +
      '<h1 class="detail-title">' + esc(e.title) + '</h1>' +
      '<div class="detail-club">' + esc(e.club) + '</div>' +
      '<div class="detail-rows">' + rows + '</div>' +
      rulebookBtn + regBlock +
    '</div>'
  );
}

function renderNotices(){
  var sorted = NOTICES.slice().sort(function(a,b){ return (b.pinned?1:0) - (a.pinned?1:0); });
  var cards = sorted.map(function(n){
    var sc = SCOPE_STYLE[n.scope];
    var pillBg = sc.color + '24';
    return (
      '<div class="notice-card">' +
        '<div class="notice-top">' +
          '<span class="scope-pill" style="color:'+sc.color+';background:'+pillBg+'">' + sc.label + (n.club ? ' · ' + esc(n.club) : '') + '</span>' +
          (n.pinned ? icon('pin',13,'#C9A227') : '') +
        '</div>' +
        '<div class="notice-title">' + esc(n.title) + '</div>' +
        '<div class="notice-body">' + esc(n.body) + '</div>' +
        '<div class="notice-time">' + esc(n.time) + '</div>' +
      '</div>'
    );
  }).join('');
  return (
    '<div class="screen-head"><div class="eyebrow">Stay in the loop</div><h1>Notices</h1></div>' +
    '<div class="chiprow">' +
      '<button class="chip active">All</button>' +
      '<button class="chip">Institute</button>' +
      '<button class="chip">Hostel</button>' +
      '<button class="chip">Club</button>' +
    '</div>' +
    '<div class="notice-list">' + cards + '</div>'
  );
}

function renderMore(){
  function row(iconName, title, sub){
    return (
      '<div class="more-row">' +
        icon(iconName, 18, '#1F3D2E') +
        '<div class="more-mid"><div class="more-title">'+esc(title)+'</div><div class="more-sub">'+esc(sub)+'</div></div>' +
        icon('chevRight', 16, 'rgba(27,27,23,.32)') +
      '</div>'
    );
  }
  return (
    '<div class="screen-head"><div class="eyebrow">Account</div><h1>More</h1></div>' +
    '<div class="more-section">' +
      row('pkg', 'Club inventory', "View and manage Dance club's gear") +
      row('msgWarn', 'Raise a complaint', 'Private to admin only') +
      row('bell', 'Notification preferences', "Mute clubs you don't follow") +
      row('alertCircle', 'Submit a score (rep)', 'Pending admin verification') +
    '</div>' +
    '<div class="profile-card">' +
      '<div class="profile-avatar">AS</div>' +
      '<div class="more-mid"><div class="more-title">Aarav Sharma</div><div class="more-sub">2023CS10123 · Satpura · Dance Rep</div></div>' +
    '</div>'
  );
}

var TABS = [
  { id: "leaderboard", label: "Standings", iconName: "trophy" },
  { id: "calendar", label: "Calendar", iconName: "calendar" },
  { id: "notices", label: "Notices", iconName: "bell" },
  { id: "more", label: "More", iconName: "more" }
];

function renderTabbar(){
  return TABS.map(function(t){
    var active = state.tab === t.id && !state.openEvent;
    var color = active ? '#1F3D2E' : 'rgba(27,27,23,.32)';
    return (
      '<button class="tab-btn ' + (active?"active":"") + '" data-action="set-tab" data-tab="'+t.id+'">' +
        icon(t.iconName, 20, color) +
        '<span class="tab-label">'+t.label+'</span>' +
      '</button>'
    );
  }).join('');
}

function render(){
  var scrollArea = document.getElementById('scrollArea');
  var html = '<div class="screen">';
  if (state.openEvent !== null){
    html += renderEventDetail(state.openEvent);
  } else if (state.tab === 'leaderboard'){
    html += renderLeaderboard();
  } else if (state.tab === 'calendar'){
    html += renderCalendar();
  } else if (state.tab === 'notices'){
    html += renderNotices();
  } else {
    html += renderMore();
  }
  html += '</div>';
  scrollArea.innerHTML = html;
  scrollArea.scrollTop = 0;
  document.getElementById('tabbar').innerHTML = renderTabbar();
}

// ---------------- Event delegation ----------------
document.addEventListener('click', function(ev){
  var el = ev.target.closest('[data-action]');
  if (!el) return;
  var action = el.getAttribute('data-action');
  if (action === 'set-tab'){
    setState({ tab: el.getAttribute('data-tab'), openEvent: null });
  } else if (action === 'board-overall'){
    setState({ boardView: 'overall' });
  } else if (action === 'board-club'){
    setState({ boardView: 'club' });
  } else if (action === 'select-day'){
    setState({ selectedDay: parseInt(el.getAttribute('data-day'), 10) });
  } else if (action === 'open-event'){
    setState({ openEvent: parseInt(el.getAttribute('data-id'), 10) });
  } else if (action === 'back-to-calendar'){
    setState({ openEvent: null });
  }
});

render();
</script>
</body>
</html>
